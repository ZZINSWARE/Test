				task.wait(3)
				stopHold()
				return
			end
	
			btnLabel.Text = "Joining (" .. playerCount .. " players)..."
			task.wait(0.5)
	
			local ok, err = pcall(function()
				TeleportService:TeleportToPlaceInstance(PLACE_ID, jobId, LocalPlayer)
			end)
	
			if not ok then
				btnLabel.Text = "Teleport failed!"
				task.wait(3)
				stopHold()
			end
		end)
	end
	
